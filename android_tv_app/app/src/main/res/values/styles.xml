<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="@android:style/Theme.Material.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:colorAccent">@color/tv_action</item>
        <item name="android:navigationBarColor">@color/tv_bg</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:statusBarColor">@color/tv_bg</item>
        <item name="android:windowBackground">@color/tv_bg</item>
    </style>

    <style name="TvHeroButton">
        <item name="android:background">@drawable/tv_focus_action</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:gravity">center</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:minHeight">80dp</item>
        <item name="android:paddingStart">18dp</item>
        <item name="android:paddingEnd">18dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/tv_text</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TvCardButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">64dp</item>
        <item name="android:layout_marginEnd">12dp</item>
        <item name="android:background">@drawable/tv_focus_card</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:gravity">center</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:minWidth">168dp</item>
        <item name="android:paddingStart">18dp</item>
        <item name="android:paddingEnd">18dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/tv_text</item>
        <item name="android:textSize">22sp</item>
    </style>

    <style name="TvSectionLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textColor">@color/tv_text</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TvInfoPanel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/tv_panel</item>
        <item name="android:padding">14dp</item>
        <item name="android:textColor">@color/tv_text</item>
        <item name="android:textSize">18sp</item>
    </style>
</resources>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:orientation="vertical"
    android:paddingStart="42dp"
    android:paddingTop="26dp"
    android:paddingEnd="42dp"
    android:paddingBottom="24dp">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/appName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:text="@string/app_name"
            android:textColor="@color/tv_text"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/statusTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="end|center_vertical"
            android:includeFontPadding="false"
            android:singleLine="true"
            android:text="@string/status_disconnected"
            android:textColor="@color/tv_muted"
            android:textSize="28sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/statusText"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <ScrollView
        android:id="@+id/pageScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipChildren="true"
        android:clipToPadding="true"
        android:descendantFocusability="afterDescendants"
        android:fillViewport="true"
        android:focusable="false"
        android:overScrollMode="never"
        android:paddingTop="26dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:id="@+id/page"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/heroRow"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:gravity="center"
                android:orientation="horizontal">

                <Space
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <Button
                    android:id="@+id/startButton"
                    style="@style/TvHeroButton"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="3"
                    android:nextFocusDown="@id/countryScroll"
                    android:text="@string/action_start_vpn" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />
            </LinearLayout>

            <TextView
                style="@style/TvSectionLabel"
                android:layout_marginTop="26dp"
                android:text="@string/section_country" />

            <HorizontalScrollView
                android:id="@+id/countryScroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:descendantFocusability="afterDescendants"
                android:focusable="false"
                android:overScrollMode="never"
                android:paddingTop="8dp"
                android:paddingBottom="10dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/countryBar"
                    android:layout_width="wrap_content"
                    android:layout_height="70dp"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:gravity="center_vertical"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <LinearLayout
                android:id="@+id/homeActions"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="14dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/detailToggleButton"
                    style="@style/TvCardButton"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1.35"
                    android:text="@string/action_choose_server" />

                <Button
                    android:id="@+id/disconnectButton"
                    style="@style/TvCardButton"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_marginEnd="0dp"
                    android:layout_weight="1"
                    android:text="@string/action_disconnect"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/privacyButton"
                    style="@style/TvCardButton"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_marginEnd="0dp"
                    android:layout_weight="0.65"
                    android:text="@string/action_privacy" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/detailSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <HorizontalScrollView
                    android:id="@+id/toolbarScroll"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/toolbar"
                        android:layout_width="wrap_content"
                        android:layout_height="64dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/speedButton"
                            style="@style/TvCardButton"
                            android:text="@string/action_speed" />

                        <Button
                            android:id="@+id/pingButton"
                            style="@style/TvCardButton"
                            android:text="@string/action_ping" />

                        <Button
                            android:id="@+id/scoreButton"
                            style="@style/TvCardButton"
                            android:text="@string/action_score" />

                        <Button
                            android:id="@+id/guideButton"
                            style="@style/TvCardButton"
                            android:text="@string/action_quality_off" />

                        <Button
                            android:id="@+id/refreshButton"
                            style="@style/TvCardButton"
                            android:text="@string/action_refresh" />

                        <Button
                            android:id="@+id/ipButton"
                            style="@style/TvCardButton"
                            android:text="@string/action_check_ip" />
                    </LinearLayout>
                </HorizontalScrollView>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/table"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </HorizontalScrollView>

                <Button
                    android:id="@+id/connectButton"
                    style="@style/TvHeroButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="12dp"
                    android:text="@string/action_connect_selected" />

                <TextView
                    android:id="@+id/detail"
                    style="@style/TvInfoPanel"
                    android:layout_marginTop="12dp"
                    android:text="@string/selected_server_none" />

                <TextView
                    android:id="@+id/log"
                    style="@style/TvInfoPanel"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <TextView
        android:id="@+id/footerInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:includeFontPadding="false"
        android:singleLine="true"
        android:textColor="@color/tv_muted"
        android:textSize="14sp" />
</LinearLayout>
